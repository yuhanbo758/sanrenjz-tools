{
  "pluginName": "AI 屏幕翻译",
  "description": "基于硅基流动 DeepSeek 模型的文本与截图翻译插件，支持中英互译与OCR识别。",
  "version": "1.0.1",
  "author": "余汉波",
  "category": "AI 工具",
  "main": "index.html",
  "logo": "logo.ico",
  "preload": "preload.js",
  "features": [
    {
      "code": "ai-screen-text-translate",
      "explain": "DeepSeek 文本翻译",
      "description": "选中文本或复制文本后使用，自动进行中英互译",
      "cmds": [
        "翻译",
        "文本翻译",
        "translate",
        "DeepSeek",
        {
          "type": "over",
          "label": "DeepSeek 翻译",
          "minLength": 1,
          "maxLength": 10000
        }
      ],
      "icon": "logo.ico",
      "platform": [
        "win32",
        "darwin",
        "linux"
      ],
      "mode": "none",
      "superPanel": true,
      "priority": 100
    },
    {
      "code": "ai-screen-ocr-translate",
      "explain": "DeepSeek 截图翻译",
      "description": "复制图片或截图到剪贴板后使用，自动识别翻译",
      "cmds": [
        "截图翻译",
        "OCR翻译",
        "screen translate",
        {
          "type": "img",
          "label": "DeepSeek 截图翻译"
        }
      ],
      "icon": "logo.ico",
      "platform": [
        "win32",
        "darwin",
        "linux"
      ],
      "mode": "none",
      "superPanel": true,
      "priority": 100
    }
  ],
  "pluginSetting": {
    "width": 900,
    "height": 620,
    "single": true,
    "autoHideMenuBar": true,
    "menuBarVisible": false
  }
}
