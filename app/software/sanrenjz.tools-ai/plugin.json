{
  "pluginName": "余汉波AI助手",
  "description": "AI对话助手，支持多种模型和API",
  "version": "1.4.0",
  "author": "余汉波",
  "category": "效率工具",
  "main": "index.html",
  "logo": "logo.png",
  "preload": "preload.js",
  "features": [
    {
      "code": "ai",
      "explain": "AI助手",
      "icon": "logo.ico",
      "superPanel": true,
      "cmds": [
        "AI助手",
        "GPT",
        {
          "type": "over",
          "label": [ "AI助手", "GPT"],
          "minLength": 1,
          "maxLength": 50000
        }
      ]
    }
  ],
  "storageFeatures": [
    {
      "storageKey": "ai-settings.quickCommands",
      "itemTitleKey": "title",
      "codePrefix": "quick-",
      "description": "AI 助手快捷指令"
    }
  ],
  "pluginSetting": {
    "width": 1000,
    "height": 680,
    "single": true,
    "autoHideMenuBar": true
  }
} 
